---
import { getCollection } from 'astro:content';
import Layout       from '../layouts/Layout.astro';
import InsiderHero  from '../components/sections/InsiderHero.astro';
import BlogCard     from '../components/ui/BlogCard.astro';
import insiderData  from '../data/insider.json';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [...new Set(posts.map(p => p.data.category))];
const featured   = posts[0];

type ColorSet = { dot: string; pill: string };

const categoryColors: Record<string, ColorSet> = {
  'News & Updates':     { dot: 'bg-amber-400', pill: 'bg-amber-50 text-amber-800' },
  'Resources & Guides': { dot: 'bg-rose-400',  pill: 'bg-rose-50 text-rose-800'   },
  'Pet Care Tips':      { dot: 'bg-sky-400',   pill: 'bg-sky-50 text-sky-800'     },
};

function getColors(cat: string): ColorSet {
  return categoryColors[cat] ?? {
    dot:  'bg-[var(--color-accent)]',
    pill: 'bg-[var(--color-muted)] text-[var(--color-muted-foreground)]',
  };
}

const featuredColors = featured ? getColors(featured.data.category) : null;
---

<Layout title={insiderData.title} description={insiderData.description} heroIsDark={false}>

  <!-- ── Editorial Hero ─────────────────────────────────── -->
  <InsiderHero
    heading={insiderData.heroHeading}
    subheading={insiderData.heroSubheading}
  />

  <!-- ── Featured latest post ──────────────────────────── -->
  {featured && featuredColors && (
    <section class="container mx-auto px-6 lg:px-10 mb-16">
      <a
        href={`/insider/${featured.id}`}
        class="group grid lg:grid-cols-2 gap-8 lg:gap-12 items-center"
      >
        {featured.data.image && (
          <div class="rounded-2xl overflow-hidden aspect-[4/3] lg:aspect-[5/4]">
            <img
              src={featured.data.image}
              alt={featured.data.imageAlt ?? featured.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="eager"
            />
          </div>
        )}
        <div class="flex flex-col gap-4">
          <span class={`self-start inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium ${featuredColors.pill}`}>
            <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${featuredColors.dot}`}></span>
            {featured.data.category}
          </span>
          <h2 class="font-serif text-2xl lg:text-3xl xl:text-4xl font-semibold leading-snug group-hover:text-[var(--color-primary)] transition-colors">
            {featured.data.title}
          </h2>
          <p class="text-[var(--color-muted-foreground)] leading-relaxed">
            {featured.data.excerpt}
          </p>
        </div>
      </a>
    </section>
  )}

  <!-- ── Filter + Grid ─────────────────────────────────── -->
  <section class="container mx-auto px-6 lg:px-10 pb-24">

    <!-- Filter pills -->
    <div class="flex items-center gap-3 flex-wrap justify-center mb-10">
      <button
        data-filter-btn="all"
        aria-pressed="true"
        class="filter-pill inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-sm font-medium transition-all cursor-pointer"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-foreground)] pill-dot-all"></span>
        All
      </button>
      {categories.map(cat => {
        const c = getColors(cat);
        return (
          <button
            data-filter-btn={cat}
            aria-pressed="false"
            class="filter-pill inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-sm font-medium transition-all cursor-pointer"
          >
            <span class={`w-2 h-2 rounded-full shrink-0 ${c.dot}`}></span>
            {cat}
          </button>
        );
      })}
    </div>

    <!-- Blog cards grid -->
    <div id="blog-grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-6">
      {posts.map(post => (
        <BlogCard
          href={`/insider/${post.id}`}
          title={post.data.title}
          excerpt={post.data.excerpt}
          category={post.data.category}
          image={post.data.image}
          imageAlt={post.data.imageAlt}
        />
      ))}
    </div>

  </section>
</Layout>

<style>
  .filter-pill {
    background-color: transparent;
    border-color: var(--color-border);
    color: var(--color-foreground);
  }
  .filter-pill[aria-pressed="true"] {
    background-color: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
  .filter-pill[aria-pressed="true"] .pill-dot-all {
    background-color: var(--color-background);
  }
  .filter-pill:hover:not([aria-pressed="true"]) {
    background-color: var(--color-muted);
  }
</style>

<script>
  const btns  = document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]');
  const cards = document.querySelectorAll<HTMLElement>('[data-card-category]');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filterBtn!;

      btns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.cardCategory === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
