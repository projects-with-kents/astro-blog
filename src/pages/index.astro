---
import Layout      from '../layouts/Layout.astro';
import PageBuilder from '../components/PageBuilder.astro';
const pagesModules = import.meta.glob('../data/pages/*.json', { eager: true });
const pagesData = Object.values(pagesModules).map((m: any) => m.default ?? m);

// Get the index page (homepage)
const homePage = pagesData.find((p) => p.slug === 'index');

if (!homePage) {
  throw new Error('Home page not found in src/data/pages collection');
}

const heroIsDark = homePage.sections[0]?.type === 'hero';
---
<Layout
  title={homePage.title}
  description={homePage.description}
  heroIsDark={heroIsDark}
>
  <PageBuilder sections={homePage.sections as any} />
</Layout>
