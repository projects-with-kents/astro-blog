---
import Layout      from '../layouts/Layout.astro';
import PageBuilder from '../components/PageBuilder.astro';
import homeData    from '../data/home.json';

// Hero is always the first block — drive the navbar dark-mode from data
const heroIsDark = homeData.sections[0]?.type === 'hero';
---

<Layout
  title="VetCare — Compassionate Care for Your Pets"
  heroIsDark={heroIsDark}
>
  <PageBuilder sections={homeData.sections as any} />
</Layout>
