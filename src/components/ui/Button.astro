---
interface Props {
  variant?: 'default' | 'outline' | 'ghost' | 'hero' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: any;
}

const {
  variant = 'default',
  size = 'md',
  href,
  class: className = '',
  type = 'button',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2.5 font-medium rounded-full border transition-all duration-200 cursor-pointer';

const variants: Record<string, string> = {
  /** Filled primary brown — default CTA */
  default:   'bg-[var(--color-primary)] text-[var(--color-primary-foreground)] border-[var(--color-primary)] hover:opacity-90',
  /** Outlined, inherits color from parent — good on light bg */
  outline:   'bg-transparent border-current hover:bg-black/5',
  /** No border, no bg — subtle action on light bg */
  ghost:     'border-transparent bg-transparent hover:bg-[var(--color-muted)] text-[var(--color-foreground)]',
  /** Cream/secondary fill — warm accent */
  secondary: 'bg-[var(--color-secondary)] text-[var(--color-secondary-foreground)] border-[var(--color-secondary)] hover:opacity-90',
  /** White outline on dark/photo backgrounds (hero sections) */
  hero:      'bg-transparent border-white/80 text-white hover:bg-white hover:text-[var(--color-foreground)]',
};

const sizes: Record<string, string> = {
  sm: 'text-xs px-4 py-1.5',
  md: 'text-sm px-5 py-2.5',
  lg: 'text-base px-7 py-3',
};

const classes = [base, variants[variant], sizes[size], className]
  .filter(Boolean)
  .join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
