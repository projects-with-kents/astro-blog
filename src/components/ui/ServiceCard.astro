---
/**
 * ServiceCard — individual card in the services grid.
 * Icon is rendered as an inline SVG chosen by the `icon` key.
 */
interface Props {
  icon:        string;
  title:       string;
  description: string;
  href:        string;
}

const { icon, title, description, href } = Astro.props;

/** Inline SVG paths keyed by service slug */
const icons: Record<string, string> = {
  transport: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    <polyline points="9 22 9 12 15 12 15 22"/>
  </svg>`,
  wellness: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M19 10l-1.5 7.5a2 2 0 0 1-2 1.5H8.5a2 2 0 0 1-2-1.5L5 10"/>
    <path d="M3 6h18"/>
    <path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/>
    <line x1="12" y1="11" x2="12" y2="16"/>
    <line x1="9.5" y1="13.5" x2="14.5" y2="13.5"/>
  </svg>`,
  walking: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="13" cy="4" r="1.5"/>
    <path d="M7.5 21l2.5-6 3 3 2-8"/>
    <path d="M17 21l-1.5-4"/>
    <path d="M5 12l2-3 3 1 2-4"/>
  </svg>`,
  training: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="7" cy="9" rx="3" ry="2"/>
    <ellipse cx="17" cy="9" rx="3" ry="2"/>
    <path d="M4 9c0 4 3 7 8 7s8-3 8-7"/>
    <path d="M12 16v3"/>
    <path d="M9 19h6"/>
  </svg>`,
  boarding: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M3 9a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/>
    <path d="M8 19v2M16 19v2"/>
    <path d="M3 13h18"/>
    <circle cx="8" cy="11" r="1.5" fill="currentColor" stroke="none"/>
  </svg>`,
  grooming: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M14.5 4.5c0 2.5-2 4-2 6s2 3.5 2 6"/>
    <path d="M9.5 4.5c0 2.5 2 4 2 6s-2 3.5-2 6"/>
    <path d="M5 8c0 3 2 5 7 5s7-2 7-5"/>
  </svg>`,
};

const svgIcon = icons[icon] ?? icons['wellness'];
---

<a
  href={href}
  class="group flex flex-col gap-5 p-7 bg-white rounded-2xl border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-0.5 transition-all duration-250"
>
  <!-- Icon bubble -->
  <div class="w-12 h-12 rounded-xl bg-[var(--color-muted)] text-[var(--color-accent)] flex items-center justify-center shrink-0">
    <div class="w-6 h-6" set:html={svgIcon} />
  </div>

  <!-- Text -->
  <div class="flex flex-col gap-2 flex-1">
    <h3 class="font-serif text-xl font-semibold text-[var(--color-foreground)]">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Learn more -->
  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors">
    Learn more
    <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </span>
</a>
