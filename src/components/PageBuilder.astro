---
/**
 * PageBuilder — renders an ordered list of content blocks.
 *
 * Each block in the `sections` array must have a `type` key that matches
 * one of the registered block components below.
 *
 * Adding a new block type:
 *  1. Create the section component in src/components/sections/
 *  2. Import it here
 *  3. Add a case to the switch in the template
 *  4. Add the block definition to .pages.yml under content[home].fields[sections].blocks
 */
import Hero         from './sections/Hero.astro';
import Services     from './sections/Services.astro';
import Feature      from './sections/Feature.astro';
import Testimonials from './sections/Testimonials.astro';
import CTA          from './sections/CTA.astro';
import FAQ          from './sections/FAQ.astro';
import InsiderHero  from './sections/InsiderHero.astro';

type HeroBlock = {
  type: 'hero';
  image: string;
  imageAlt: string;
  badge?: string;
  /** Use *asterisks* for italic parts */
  heading: string;
  subheading: string;
  cta: { label: string; href: string };
};

type ServiceItem = {
  icon?: string;
  title: string;
  description: string;
  href: string;
};

type ServicesBlock = {
  type: 'services';
  heading: string;
  subheading: string;
  items: ServiceItem[];
};

type FeatureListItem = {
  text: string;
  bulletIcon?: string;
};

type FeatureBlock = {
  type: 'feature';
  layout?: 'image-left' | 'image-right' | 'no-image';
  image?: string;
  imageAlt?: string;
  heading: string;
  body: string;
  features: FeatureListItem[];
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
};

type Testimonial = {
  image?: string;
  imageAlt?: string;
  rating: number;
  quote: string;
  text: string;
  author: string;
};

type TestimonialsBlock = {
  type: 'testimonials';
  heading: string;
  subheading?: string;
  testimonials: Testimonial[];
};

type CTABlock = {
  type: 'cta';
  heading: string;
  body: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  backgroundColor?: string;
};

type FAQItem = {
  question: string;
  answer: string;
};

type FAQBlock = {
  type: 'faq';
  heading: string;
  body?: string;
  faqs: FAQItem[];
  cta?: { label: string; href: string };
};

type InsiderHeroBlock = {
  type: 'insider-hero';
  heading: string;
  subheading?: string;
};

type Block = HeroBlock | ServicesBlock | FeatureBlock | TestimonialsBlock | CTABlock | FAQBlock | InsiderHeroBlock;

interface Props {
  sections: Block[];
}

const { sections } = Astro.props;
---

{sections.map((block) => {
  switch (block.type) {
    case 'hero':
      return (
        <Hero
          image={block.image}
          imageAlt={block.imageAlt}
          badge={block.badge}
          heading={block.heading}
          subheading={block.subheading}
          cta={block.cta}
        />
      );

    case 'services':
      return (
        <Services
          heading={block.heading}
          subheading={block.subheading}
          items={block.items}
        />
      );

    case 'feature':
      return (
        <Feature
          layout={block.layout}
          image={block.image}
          imageAlt={block.imageAlt}
          heading={block.heading}
          body={block.body}
          features={block.features}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
        />
      );

    case 'testimonials':
      return (
        <Testimonials
          heading={block.heading}
          subheading={block.subheading}
          testimonials={block.testimonials}
        />
      );

    case 'cta':
      return (
        <CTA
          heading={block.heading}
          body={block.body}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
          backgroundColor={block.backgroundColor}
        />
      );

    case 'faq':
      return (
        <FAQ
          heading={block.heading}
          body={block.body}
          faqs={block.faqs}
          cta={block.cta}
        />
      );

    case 'insider-hero':
      return (
        <InsiderHero
          heading={block.heading}
          subheading={block.subheading}
        />
      );

    default:
      // Unknown block type — skip silently in production
      return null;
  }
})}
