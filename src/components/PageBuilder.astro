---
/**
 * PageBuilder — renders an ordered list of content blocks.
 *
 * Each block in the `sections` array must have a `type` key that matches
 * one of the registered block components below.
 *
 * Adding a new block type:
 *  1. Create the section component in src/components/sections/
 *  2. Import it here
 *  3. Add a case to the switch in the template
 *  4. Add the block definition to .pages.yml under content[home].fields[sections].blocks
 */
import Hero         from './sections/Hero.astro';
import Services     from './sections/Services.astro';
import Feature      from './sections/Feature.astro';
import Testimonials from './sections/Testimonials.astro';
import CTA          from './sections/CTA.astro';
import FAQ          from './sections/FAQ.astro';
import InsiderHero  from './sections/InsiderHero.astro';
import ContactForm  from './sections/ContactForm.astro';
import HeroCentered from './sections/HeroCentered.astro';
import MediaCentered from './sections/MediaCentered.astro';
import Gallery from './sections/Gallery.astro';
import StatsText from './sections/StatsText.astro';
import LightCTAWithPhoto from './sections/LightCTAWithPhoto.astro';
import MarkdownContent from './sections/MarkdownContent.astro';
import PolaroidScroll from './sections/PolaroidScroll.astro';

type HeroBlock = {
  type: 'hero';
  image: string;
  imageAlt: string;
  badge?: string;
  /** Use *asterisks* for italic parts */
  heading: string;
  subheading: string;
  cta: { label: string; href: string };
};

type ServiceItem = {
  icon?: string;
  title: string;
  description: string;
  href: string;
};

type ServicesBlock = {
  type: 'services';
  heading: string;
  subheading: string;
  items: ServiceItem[];
};

type FeatureListItem = {
  text: string;
  bulletIcon?: string;
};

type FeatureBlock = {
  type: 'feature';
  layout?: 'image-left' | 'image-right' | 'no-image';
  image?: string;
  imageAlt?: string;
  heading: string;
  body: string;
  features: FeatureListItem[];
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
};

type Testimonial = {
  image?: string;
  imageAlt?: string;
  rating: number;
  quote: string;
  text: string;
  author: string;
};

type TestimonialsBlock = {
  type: 'testimonials';
  heading: string;
  subheading?: string;
  testimonials: Testimonial[];
};

type CTABlock = {
  type: 'cta';
  heading: string;
  body: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  backgroundColor?: string;
};

type FAQItem = {
  question: string;
  answer: string;
};

type FAQBlock = {
  type: 'faq';
  heading: string;
  body?: string;
  faqs: FAQItem[];
  cta?: { label: string; href: string };
};

type InsiderHeroBlock = {
  type: 'insider-hero';
  heading: string;
  subheading?: string;
};

type ContactFormBlock = {
  type: 'contact-form';
  heading: string;
  body?: string;
  endpointUrl: string;
  submitLabel?: string;
  note?: string;
};

type HeroCenteredBlock = {
  type: 'hero-centered';
  badge?: string;
  heading: string;
  subheading?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
};

type MediaCenteredBlock = {
  type: 'media-centered';
  kind?: 'image' | 'video';
  image?: string;
  imageAlt?: string;
  videoSrc?: string;
  poster?: string;
  caption?: string;
};

type GalleryItem = {
  image: string;
  imageAlt?: string;
  caption?: string;
};

type GalleryBlock = {
  type: 'gallery';
  heading?: string;
  body?: string;
  variant?: 'grid-2' | 'mosaic' | 'strip';
  items: GalleryItem[];
};

type StatsItem = {
  value: string;
  label: string;
};

type StatsTextBlock = {
  type: 'stats-text';
  heading: string;
  body?: string;
  stats: StatsItem[];
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
};

type LightCTAWithPhotoBlock = {
  type: 'light-cta-photo';
  heading: string;
  body?: string;
  image: string;
  imageAlt?: string;
  cta: { label: string; href: string };
};

type MarkdownContentBlock = {
  type: 'markdown-content';
  heading?: string;
  markdown: string;
};

type PolaroidPhotoItem = {
  image: string;
  imageAlt?: string;
  note?: string;
};

type PolaroidScrollBlock = {
  type: 'polaroid-scroll';
  heading: string;
  photos: PolaroidPhotoItem[];
  body?: string;
  cta?: { label?: string; href?: string };
};

type Block = HeroBlock | ServicesBlock | FeatureBlock | TestimonialsBlock | CTABlock | FAQBlock | InsiderHeroBlock | ContactFormBlock | HeroCenteredBlock | MediaCenteredBlock | GalleryBlock | StatsTextBlock | LightCTAWithPhotoBlock | MarkdownContentBlock | PolaroidScrollBlock;

interface Props {
  sections: Block[];
}

const { sections } = Astro.props;

type LegacyBlock = Block;
type KeystaticBlock = { discriminant: string; value: Record<string, unknown> };

function normalizeBlock(raw: LegacyBlock | KeystaticBlock | null | undefined): Block | null {
  if (!raw || typeof raw !== 'object') return null;

  if ('type' in raw) {
    return raw as Block;
  }

  if ('discriminant' in raw && 'value' in raw) {
    const ks = raw as KeystaticBlock;
    return {
      type: ks.discriminant,
      ...(ks.value ?? {}),
    } as Block;
  }

  return null;
}
---

{sections.map((rawBlock) => {
  const block = normalizeBlock(rawBlock as LegacyBlock | KeystaticBlock);
  if (!block) return null;

  switch (block.type) {
    case 'hero':
      return (
        <Hero
          image={block.image}
          imageAlt={block.imageAlt}
          badge={block.badge}
          heading={block.heading}
          subheading={block.subheading}
          cta={block.cta}
        />
      );

    case 'services':
      return (
        <Services
          heading={block.heading}
          subheading={block.subheading}
          items={block.items}
        />
      );

    case 'feature':
      return (
        <Feature
          layout={block.layout}
          image={block.image}
          imageAlt={block.imageAlt}
          heading={block.heading}
          body={block.body}
          features={block.features}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
        />
      );

    case 'testimonials':
      return (
        <Testimonials
          heading={block.heading}
          subheading={block.subheading}
          testimonials={block.testimonials}
        />
      );

    case 'cta':
      return (
        <CTA
          heading={block.heading}
          body={block.body}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
          backgroundColor={block.backgroundColor}
        />
      );

    case 'faq':
      return (
        <FAQ
          heading={block.heading}
          body={block.body}
          faqs={block.faqs}
          cta={block.cta}
        />
      );

    case 'insider-hero':
      return (
        <InsiderHero
          heading={block.heading}
          subheading={block.subheading}
        />
      );

    case 'contact-form':
      return (
        <ContactForm
          heading={block.heading}
          body={block.body}
          endpointUrl={block.endpointUrl}
          submitLabel={block.submitLabel}
          note={block.note}
        />
      );

    case 'hero-centered':
      return (
        <HeroCentered
          badge={block.badge}
          heading={block.heading}
          subheading={block.subheading}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
        />
      );

    case 'media-centered':
      return (
        <MediaCentered
          kind={block.kind}
          image={block.image}
          imageAlt={block.imageAlt}
          videoSrc={block.videoSrc}
          poster={block.poster}
          caption={block.caption}
        />
      );

    case 'gallery':
      return (
        <Gallery
          heading={block.heading}
          body={block.body}
          variant={block.variant}
          items={block.items}
        />
      );

    case 'stats-text':
      return (
        <StatsText
          heading={block.heading}
          body={block.body}
          stats={block.stats}
          ctaPrimary={block.ctaPrimary}
          ctaSecondary={block.ctaSecondary}
        />
      );

    case 'light-cta-photo':
      return (
        <LightCTAWithPhoto
          heading={block.heading}
          body={block.body}
          image={block.image}
          imageAlt={block.imageAlt}
          cta={block.cta}
        />
      );

    case 'markdown-content':
      return (
        <MarkdownContent
          heading={block.heading}
          markdown={block.markdown}
        />
      );

    case 'polaroid-scroll':
      return (
        <PolaroidScroll
          heading={block.heading}
          photos={block.photos}
          body={block.body}
          cta={block.cta}
        />
      );

    default:
      // Unknown block type — skip silently in production
      return null;
  }
})}
