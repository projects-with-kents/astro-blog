---
interface GalleryItem {
  image: string;
  imageAlt?: string;
  caption?: string;
}

interface Props {
  heading?: string;
  body?: string;
  variant?: 'grid-2' | 'mosaic' | 'strip';
  items: GalleryItem[];
}

const {
  heading,
  body,
  variant = 'grid-2',
  items = [],
} = Astro.props;

const safeItems = items.filter((item: GalleryItem) => !!item.image);
---

<section class="py-16 lg:py-24">
  <div class="container mx-auto px-6 lg:px-10">
    {(heading || body) && (
      <div class="max-w-3xl mb-10">
        {heading && <h2 class="font-serif text-3xl lg:text-5xl font-semibold leading-tight mb-4">{heading}</h2>}
        {body && <p class="text-muted-foreground text-base lg:text-lg leading-relaxed">{body}</p>}
      </div>
    )}

    {variant === 'grid-2' && (
      <div class="grid md:grid-cols-2 gap-6">
        {safeItems.map((item: GalleryItem) => (
          <figure class="rounded-3xl overflow-hidden border border-border bg-white">
            <img src={item.image} alt={item.imageAlt ?? 'Gallery image'} loading="lazy" class="w-full h-[min(60vh,520px)] object-cover" />
            {item.caption && <figcaption class="px-4 py-3 text-sm text-muted-foreground">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    {variant === 'mosaic' && (
      <div class="grid md:grid-cols-12 gap-5 auto-rows-[180px]">
        {safeItems.map((item: GalleryItem, index: number) => {
          const className = index % 5 === 0
            ? 'md:col-span-7 md:row-span-2'
            : index % 3 === 0
              ? 'md:col-span-5 md:row-span-2'
              : 'md:col-span-5 md:row-span-1';

          return (
            <figure class={`rounded-3xl overflow-hidden border border-border bg-white ${className}`}>
              <img src={item.image} alt={item.imageAlt ?? 'Gallery image'} loading="lazy" class="w-full h-full object-cover" />
            </figure>
          );
        })}
      </div>
    )}

    {variant === 'strip' && (
      <div class="grid md:grid-cols-3 gap-5">
        {safeItems.map((item: GalleryItem) => (
          <figure class="rounded-3xl overflow-hidden border border-border bg-white">
            <img src={item.image} alt={item.imageAlt ?? 'Gallery image'} loading="lazy" class="w-full h-[320px] object-cover" />
            {item.caption && <figcaption class="px-4 py-3 text-sm text-muted-foreground">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
  </div>
</section>
