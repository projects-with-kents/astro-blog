---
import Button from '../ui/Button.astro';

interface StatItem {
  value: string;
  label: string;
}

interface Props {
  heading: string;
  body?: string;
  stats: StatItem[];
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
}

const {
  heading,
  body,
  stats = [],
  ctaPrimary,
  ctaSecondary,
} = Astro.props;
---

<section class="py-20 lg:py-28 bg-[color:color-mix(in_srgb,var(--color-secondary)_38%,white)]">
  <div class="container mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-12 items-start mb-12">
      <h2 class="font-serif text-3xl lg:text-5xl font-semibold leading-tight max-w-xl">
        {heading}
      </h2>

      <div>
        {body && <p class="text-base lg:text-lg text-muted-foreground leading-relaxed mb-8">{body}</p>}
        {(ctaPrimary || ctaSecondary) && (
          <div class="flex flex-wrap gap-3">
            {ctaPrimary && <Button href={ctaPrimary.href} size="lg">{ctaPrimary.label}</Button>}
            {ctaSecondary && (
              <Button href={ctaSecondary.href} variant="outline" size="lg" class="text-foreground border-foreground/30 hover:bg-white/70">
                {ctaSecondary.label}
              </Button>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-0 border-y border-accent/45">
      {stats.map((item: StatItem, index: number) => (
        <div class:list={[
          'py-7 px-4 lg:px-6',
          index !== 0 ? 'border-l border-accent/45' : '',
        ]}>
          <p class="text-4xl lg:text-6xl font-semibold tracking-tight mb-2">{item.value}</p>
          <p class="text-xl text-foreground/85">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
