---
import Button      from '../ui/Button.astro';
import RichHeading from '../ui/RichHeading.astro';

interface Props {
  image:      string;
  imageAlt:   string;
  badge?:     string;
  /** Heading string — wrap italic parts in *asterisks*: "Step into the *world of furry* Friends!" */
  heading:    string;
  subheading: string;
  cta: { label: string; href: string };
}

const {
  image,
  imageAlt,
  badge,
  heading,
  subheading,
  cta,
} = Astro.props;
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Background image -->
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Gradient overlay — heavy on left for readability, fades right -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/15"></div>
  <!-- Bottom vignette -->
  <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black/40 to-transparent"></div>

  <!--
    Sentinel element watched by Navbar's IntersectionObserver.
    When this leaves the viewport the navbar switches to light mode.
  -->
  <div id="hero-sentinel" class="absolute bottom-4 left-0 w-px h-px pointer-events-none" aria-hidden="true"></div>

  <!-- Content -->
  <div
    class="relative z-10 w-full container mx-auto px-6 lg:px-10 pb-20"
    style="padding-top: calc(var(--announcement-height, 40px) + 96px);"
  >
    <div class="max-w-2xl">

      <!-- Badge -->
      {badge && (
        <div class="mb-6">
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-xs font-medium px-3 py-1.5 rounded-full tracking-wide">
            {badge}
          </span>
        </div>
      )}

      <!-- Heading -->
      <RichHeading
        text={heading}
        as="h1"
        class="font-serif text-white font-bold leading-[1.15] mb-6 text-5xl lg:text-6xl xl:text-7xl"
      />

      <!-- Subheading -->
      <p class="text-white/75 text-base lg:text-lg max-w-lg mb-10 leading-relaxed">
        {subheading}
      </p>

      <!-- CTA button -->
      <Button variant="hero" size="lg" href={cta.href}>
        <!-- Paw icon -->
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <ellipse cx="5.5"  cy="6"   rx="1.8" ry="2.3"/>
          <ellipse cx="9.8"  cy="3.5" rx="1.8" ry="2.3"/>
          <ellipse cx="14.2" cy="3.5" rx="1.8" ry="2.3"/>
          <ellipse cx="18.5" cy="6"   rx="1.8" ry="2.3"/>
          <path d="M12 9.5c-4.2 0-7.5 2.8-7.5 6.3 0 1.5.7 2.8 1.9 3.8 1.2 1 2.9 1.6 5.1 1.6 2.2 0 3.9-.6 5.1-1.6 1.2-1 1.9-2.3 1.9-3.8 0-3.5-3.3-6.3-7.5-6.3z"/>
        </svg>
        {cta.label}
      </Button>

    </div>
  </div>
</section>
