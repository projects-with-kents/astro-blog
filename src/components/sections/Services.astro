---
import ServiceCard  from '../ui/ServiceCard.astro';
import RichHeading from '../ui/RichHeading.astro';

interface ServiceItem {
  icon:        string;
  title:       string;
  description: string;
  href:        string;
}

interface Props {
  heading:    string;
  subheading: string;
  items:      ServiceItem[];
}

const { heading, subheading, items } = Astro.props;
---

<section class="bg-white py-24">
  <div class="container mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <RichHeading
        text={heading}
        as="h2"
        class="font-serif text-4xl lg:text-5xl font-bold text-[var(--color-foreground)] leading-tight mb-4"
      />
      <p class="text-[var(--color-muted-foreground)] text-base lg:text-lg leading-relaxed">
        {subheading}
      </p>
    </div>

    <!-- Services grid — auto-fills rows, supports any number of cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((item) => (
        <ServiceCard
          icon={item.icon}
          title={item.title}
          description={item.description}
          href={item.href}
        />
      ))}
    </div>

  </div>
</section>
