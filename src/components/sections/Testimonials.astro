---
import RichHeading from '../ui/RichHeading.astro';

type Testimonial = {
  image?: string;
  imageAlt?: string;
  rating: number; // 1-5
  quote: string;
  text: string;
  author: string;
};

interface Props {
  heading: string;
  subheading?: string;
  testimonials: Testimonial[];
}

const { heading, subheading, testimonials = [] } = Astro.props;

const starArray = Array.from({ length: 5 });
---

<section class="bg-secondary/20 py-20 md:py-32" data-reveal-root>
  <div class="container mx-auto px-6 lg:px-10">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16">
      <div class="reveal-item">
        <RichHeading
          text={heading}
          as="h2"
          class="font-serif text-4xl lg:text-5xl font-bold text-(--color-foreground) leading-tight mb-2"
        />
        {subheading && (
          <p class="text-muted-foreground text-base lg:text-lg">
            {subheading}
          </p>
        )}
      </div>

      <!-- Navigation arrows -->
      {testimonials.length > 1 && (
        <div class="reveal-item flex gap-2 shrink-0">
          <button
            class="testimonial-prev w-11 h-11 rounded-full border border-(--color-accent) text-(--color-accent) flex items-center justify-center hover:bg-(--color-accent) hover:text-white transition-all"
            aria-label="Previous testimonial"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            class="testimonial-next w-11 h-11 rounded-full border border-(--color-foreground) text-white bg-(--color-foreground) flex items-center justify-center hover:bg-(--color-foreground)/90 transition-all"
            aria-label="Next testimonial"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      )}
    </div>

    <!-- Carousel container -->
    {testimonials.length > 0 && (
      <div class="reveal-item relative overflow-hidden">
        <div 
          class="testimonial-carousel flex transition-transform duration-500 ease-out"
          style="transform: translateX(0%)"
        >
          {testimonials.map((testimonial) => (
            <div class="w-full shrink-0">
              <div class="px-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
                  <!-- Image -->
                  {testimonial.image && (
                    <div class="rounded-3xl overflow-hidden border border-(--color-border) bg-muted">
                      <img
                        src={testimonial.image}
                        alt={testimonial.imageAlt || testimonial.author}
                        class="w-full h-90 md:h-100 object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}

                  <!-- Testimonial card -->
                  <div class:list={[
                    'bg-white rounded-3xl p-8 md:p-10 flex flex-col justify-center border border-(--color-border)',
                    testimonial.image ? '' : 'col-span-full max-w-2xl mx-auto md:max-w-none',
                  ]}>
                  <!-- Stars -->
                  <div class="flex gap-1.5 mb-6">
                    {starArray.map((_, i) => (
                      <svg
                        class:list={[
                          'w-6 h-6',
                          i < testimonial.rating
                            ? 'fill-(--color-accent) stroke-(--color-accent)'
                            : 'fill-none stroke-muted-foreground',
                        ]}
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polygon points="12 2 15.09 10.26 24 10.5 17.18 16.34 19.34 24.5 12 20.31 4.66 24.5 6.82 16.34 0 10.5 8.91 10.26" />
                      </svg>
                    ))}
                  </div>

                  <!-- Quote -->
                  <h3 class="font-serif text-2xl md:text-3xl font-bold text-(--color-foreground) leading-tight mb-5">
                    "{testimonial.quote}"
                  </h3>

                  <!-- Text -->
                  <p class="text-muted-foreground text-base leading-relaxed mb-6 flex-1">
                    {testimonial.text}
                  </p>

                  <!-- Author -->
                  <p class="text-(--color-foreground) font-medium">
                    −{testimonial.author}
                  </p>
                </div>
              </div>
            </div>
            </div>
          ))}
        </div>

        <!-- Dots indicator (если больше одного отзыва) -->
        {testimonials.length > 1 && (
          <div class="flex gap-2 justify-center mt-10">
            {testimonials.map((_, idx) => (
              <button
                class="testimonial-dot w-2.5 h-2.5 rounded-full transition-all"
                class:list={[idx === 0 ? 'bg-(--color-foreground) w-8' : 'bg-muted']}
                aria-label={`Go to testimonial ${idx + 1}`}
                data-index={idx}
              />
            ))}
          </div>
        )}
      </div>
    )}
  </div>

  <script>
    const carousel = document.querySelector('.testimonial-carousel') as HTMLElement | null;
    const prevBtn = document.querySelector('.testimonial-prev') as HTMLButtonElement | null;
    const nextBtn = document.querySelector('.testimonial-next') as HTMLButtonElement | null;
    const dots = document.querySelectorAll('.testimonial-dot') as NodeListOf<HTMLButtonElement>;

    let currentIndex = 0;

    function updateCarousel() {
      if (!carousel) return;
      const offset = currentIndex * 100;
      carousel.style.transform = `translateX(-${offset}%)`;

      // Update dots
      dots.forEach((dot, idx) => {
        if (idx === currentIndex) {
          dot.classList.add('w-8', 'bg-(--color-foreground)');
          dot.classList.remove('w-2.5', 'bg-muted');
        } else {
          dot.classList.add('w-2.5', 'bg-muted');
          dot.classList.remove('w-8', 'bg-(--color-foreground)');
        }
      });
    }

    const totalSlides = carousel ? carousel.children.length : 1;

    prevBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
      updateCarousel();
    });

    nextBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % totalSlides;
      updateCarousel();
    });

    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        currentIndex = idx;
        updateCarousel();
      });
    });

    // Initial state
    updateCarousel();
  </script>
</section>
